bin/
# Anchor to the repo root so the built binary is ignored but the
# cmd/cinc-zero/ source directory is not.
/cinc-zero
dist/
*.pem
.DS_Store
*.swp
# Generated dev databases (built from dev/test-repo via `make dev-db`).
*.db
*.db-wal
*.db-shm
# ...except the shipped dev database, which is committed as a ready-to-run fixture.
!dev/cinc-dev.db
# The large generated seed expansion (1000 nodes, etc.) is rebuilt by cmd/seedgen
# during `make dev-db`; only the baked DB is committed, not these files.
dev/seed.gen/

# don't ship the binaries
cmd/fleetsim/fleetsim
cmd/loadtest/loadtest

# don't ship the worktrees dir
.claude/workstrees/